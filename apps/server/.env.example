# AISplinter — file-first config (copy to .env, fill in, restart)
#
# Standalone: aisplinter-code/apps/server/.env
# Next.js embed: your host app .env (same vars)
#
# Full guide: docs/DEV_SETUP.md

# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

AISPLINTER_UPSTREAM_ADAPTER=openrouter
# Management key from https://openrouter.ai/keys — must provision per-user keys
AISPLINTER_OPENROUTER_KEY=sk-or-v1-...

# ── Project ─────────────────────────────────────────────────────────────────
AISPLINTER_PROJECT_NAME=MyApp

# Recommended: pin dev key (aisplinter_dev_…) so DB resets do not rotate it
# AISPLINTER_DEV_KEY=aisplinter_dev_xxxxxxxx

# Protect /admin off localhost
# AISPLINTER_ADMIN_SECRET=your-long-random-secret

# ── Standalone runner (apps/server) ───────────────────────────────────────────
PORT=8747
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ── LiteLLM (when AISPLINTER_UPSTREAM_ADAPTER=litellm) ──────────────────────
# AISPLINTER_LITELLM_BASE_URL=http://127.0.0.1:4000
# AISPLINTER_LITELLM_KEY=sk-...

# Aliases (optional)
# OPENROUTER_API_KEY=
# LITELLM_MASTER_KEY=
# LITELLM_BASE_URL=

# Wizard fallback only — if DATABASE_URL is not in .env
# AISPLINTER_DATA_DIR=.aisplinter-data/config.json
