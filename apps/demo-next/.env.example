# AISplinter — Next.js embed example
# Copy to .env.local in apps/demo-next (or merge into your host app .env)

# Reuses your app Postgres (Neon) — same as DATABASE_URL in a real host
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── AISplinter server (embedded at /api/aisplinter) ─────────────────────────
AISPLINTER_UPSTREAM_ADAPTER=openrouter
# Management / provisioning key from https://openrouter.ai/keys (not inference-only)
AISPLINTER_OPENROUTER_KEY=sk-or-v1-...
AISPLINTER_PROJECT_NAME=DemoApp

# Pin dev key so restarts stay stable (optional — generated on first boot if omitted)
# AISPLINTER_DEV_KEY=aisplinter_dev_xxxxxxxx

# Optional — protect /api/aisplinter/admin off localhost
# AISPLINTER_ADMIN_SECRET=

# ── Client vars (backend scripts / server actions only) ─────────────────────
# AISPLINTER_BASE_URL=http://localhost:3000/api/aisplinter
# AISPLINTER_DEV_KEY=aisplinter_dev_xxxxxxxx

# Do NOT prefix server secrets with NEXT_PUBLIC_
