# AISplinter server — file-first config (copy to .env wherever you host the API)
#
# Standalone: aisplinter-code/apps/server/.env
# Next.js embed: apps/web/.env (same vars)
#
# Full guide: docs/DEV_SETUP.md

# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: Postgres schema for same-database isolation (tables still named aisplinter_*)
# AISPLINTER_DB_SCHEMA=aisplinter

# Neon OAuth (optional — enables "Create with Neon" in setup wizard; user's Neon account)
# NEON_OAUTH_CLIENT_ID=
# NEON_OAUTH_CLIENT_SECRET=
# NEON_DEFAULT_REGION_ID=aws-us-east-1

# Upstream (OpenRouter is the default path)
AISPLINTER_UPSTREAM_ADAPTER=openrouter
AISPLINTER_OPENROUTER_KEY=sk-or-v1-...
# Management key from https://openrouter.ai/keys — not inference-only

# ── Project ───────────────────────────────────────────────────────────────────
AISPLINTER_PROJECT_NAME=MyApp

# Optional: pin the dev API key your app uses (aisplinter_dev_…).
# AISPLINTER_DEV_KEY=aisplinter_dev_xxxxxxxx

# Protect /admin UI & API when not on localhost (Bearer token or X-AISplinter-Admin-Secret).
# AISPLINTER_ADMIN_SECRET=your-long-random-secret

# ── Standalone only ───────────────────────────────────────────────────────────
PORT=8747
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ── LiteLLM adapter (when AISPLINTER_UPSTREAM_ADAPTER=litellm) ───────────────
# AISPLINTER_LITELLM_BASE_URL=http://127.0.0.1:4000
# AISPLINTER_LITELLM_KEY=sk-...

# ── Wizard fallback only ─────────────────────────────────────────────────────
# AISPLINTER_DATA_DIR=.aisplinter-data/config.json
