# Client / integrator — paste into your app .env (backend or desktop shell)
#
# Connects your app to a running AISplinter API.
# Server secrets (DATABASE_URL, OPENROUTER) belong in the HOST .env only.
#
# Full guide: docs/DEV_SETUP.md

# Standalone dev server (port 8747)
AISPLINTER_BASE_URL=http://127.0.0.1:8747

# Next.js embed at /api/aisplinter
# AISPLINTER_BASE_URL=http://localhost:3000/api/aisplinter

AISPLINTER_DEV_KEY=aisplinter_dev_xxxxxxxx

# Optional — skip provision if you already have a session token
# AISPLINTER_SESSION_TOKEN=aisplinter_sess_...

# Optional default plan when auto-provisioning (catalog SKU, e.g. ai_starter)
# AISPLINTER_PLAN_SKU=ai_starter

# Bundlers: never expose DEV_KEY to the browser. If needed client-side:
# VITE_AISPLINTER_BASE_URL=...
# NEXT_PUBLIC_AISPLINTER_BASE_URL=...  (URL only — not the dev key)
